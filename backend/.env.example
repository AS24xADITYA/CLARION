# ─── Ollama LLM Settings ────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_FALLBACK_MODEL=gemma:2b

# ─── Model Paths ─────────────────────────────────────────────────────────────
SCAN_MODEL_PATH=saved_models/scan_efficientnet.h5
SCAM_MODEL_PATH=saved_models/scam_distilbert

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///CLARION.db

# ─── Upload Limits ───────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=5

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_SCAN=10/minute
RATE_LIMIT_SCAM=20/minute
RATE_LIMIT_FRAUDBOT=15/minute

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
